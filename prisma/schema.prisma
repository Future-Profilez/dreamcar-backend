generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum productTypeEnum {
  car_bike
  tech_luxury
  cash
}
enum itemTypeEnum {
  competition
  gift_card
  gift_credit
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      String    @default("user")
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @db.Timestamp(0)
  deletedAt DateTime? @db.Timestamp(0)

  instantWins       InstantWin[]
  complianceAnswers ComplianceAnswer[]
  cart              Cart[]
  payments          StripePayment[]
  tickets           Ticket[]
}

model Competition {
  id               Int             @id @default(autoincrement())
  title            String
  images           String[]
  detail           String
  productType      productTypeEnum @default(car_bike)
  ticketPrice      Int
  totalTickets     Int
  soldTickets      Int             @default(0)
  startTime        DateTime
  endTime          DateTime
  prizeDetail      String
  prizeDetailImage String
  prizeFeatures    String[]

  instantWinEnabled        Boolean              @default(false)
  instantWinTriggerPercent Int?
  instantWins              InstantWin[]
  instantWinPrizes         InstantWinPrize[]
  questions                ComplianceQuestion[]
  tickets                  Ticket[]

  status    Int       @default(1)
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @db.Timestamp(0)
  deletedAt DateTime? @db.Timestamp(0)
}

model ComplianceQuestion {
  id               String             @id @default(uuid())
  competitionId    Int
  question         String
  competition      Competition        @relation(fields: [competitionId], references: [id])
  options          String[]
  answers          String[]
  ComplianceOption ComplianceOption[]
  ComplianceAnswer ComplianceAnswer[]
}

//Prize is stored here
model InstantWinPrize {
  id            String  @id @default(uuid())
  competitionId Int
  title         String // "iPhone 15"
  image         String?
  quantity      Int // 5

  competition Competition  @relation(fields: [competitionId], references: [id])
  wins        InstantWin[]
}

//Prize winner is stored here
model InstantWin {
  id            String @id @default(uuid())
  competitionId Int
  prizeId       String
  ticketNumber  Int

  isClaimed   Boolean   @default(false)
  claimedById Int?
  claimedAt   DateTime?

  competition Competition     @relation(fields: [competitionId], references: [id])
  prize       InstantWinPrize @relation(fields: [prizeId], references: [id])
  claimedBy   User?           @relation(fields: [claimedById], references: [id])

  @@unique([competitionId, ticketNumber])
}

model StripePayment {
  id             String   @id @default(uuid())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  amount         Float
  currency       String   @default("USD")
  status         String   @default("pending") // pending / success / failed
  type           itemTypeEnum

  stripePaymentId String?
  sessionId       String?

  competitionId Int?
  competition   Competition? @relation(fields: [competitionId], references: [id])
  quantity      Int?

  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @db.Timestamp(0)
}

model Cart {
  id               Int             @id @default(autoincrement())
  userId           Int             @unique 
  user             User            @relation(fields: [userId], references: [id])
  items            CartItem[]
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @db.Timestamp(0)
}

model CartItem {
  id               Int             @id @default(autoincrement())
  cartId           Int             
  itemId           Int             
  quantity         Int
  itemType         itemTypeEnum   @default(competition)
  cart Cart @relation(fields: [cartId], references: [id])    

  @@unique([cartId, itemId, itemType])                                               
}

model Ticket {
  id            String   @id @default(uuid())

  competitionId Int
  userId        Int
  paymentId     String   // instead of orderId

  ticketNumber  Int
  isEligible    Boolean
  isInstantWin  Boolean @default(false)

  createdAt     DateTime @default(now())

  competition Competition @relation(fields: [competitionId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  payment     StripePayment @relation(fields: [paymentId], references: [id])

  instantWin  InstantWin?
  winner      Winner?

  @@unique([competitionId, ticketNumber])
}