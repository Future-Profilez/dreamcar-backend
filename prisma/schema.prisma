model Competition {
  id               Int             @id @default(autoincrement())
  title            String
  images           String[]
  slug             String?         @unique
  detail           String
  productType      productTypeEnum @default(car_bike)
  ticketPrice      Int
  totalTickets     Int
  soldTickets      Int             @default(0)
  startTime        DateTime
  endTime          DateTime

  instantWinEnabled        Boolean              @default(false)
  instantWinTriggerPercent Int?
  instantWinGenerated      Boolean              @default(false)
  instantWins              InstantWin[]
  instantWinPrizes         InstantWinPrize[]
  questions                ComplianceQuestion[]
  tickets                  Ticket[]
  payments                 StripePayment[]
  results                  Result[]
  prizes                   Prize[]

  status    Int       @default(1)
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @db.Timestamp(0)
  deletedAt DateTime? @db.Timestamp(0)
}

model Prize {
  id                String   @id @default(uuid())
  competitionId     Int
  title             String
  prizeDetail       String
  prizeDetailImage  String
  prizeFeatures     String[]
  position          Int   // 1 = main winner, 2 = runner-up 1, 2 = runner-up 1
  createdAt         DateTime? @default(now()) @db.Timestamp(0)
  updatedAt         DateTime? @db.Timestamp(0)
  deletedAt         DateTime? @db.Timestamp(0)

  competition   Competition @relation(fields: [competitionId], references: [id])
  @@unique([competitionId, position]) // one prize per position
}

model ComplianceQuestion {
  id               String             @id @default(uuid())
  competitionId    Int
  question         String
  competition      Competition        @relation(fields: [competitionId], references: [id])
  options          String[]
  answers          String[]
}

//Prize is stored here
model InstantWinPrize {
  id            String  @id @default(uuid())
  competitionId Int
  title         String // "iPhone 15"
  image         String?
  quantity      Int // 5

  competition Competition  @relation(fields: [competitionId], references: [id])
  wins        InstantWin[]
}

//Prize winner is stored here
model InstantWin {
  id            String @id @default(uuid())
  competitionId Int
  prizeId       String
  ticketNumber  Int

  isClaimed   Boolean   @default(false)
  claimedById Int?
  claimedAt   DateTime?

  ticketId     String?  @unique

  competition Competition     @relation(fields: [competitionId], references: [id])
  prize       InstantWinPrize @relation(fields: [prizeId], references: [id])
  claimedBy   User?           @relation(fields: [claimedById], references: [id])
  ticket      Ticket?         @relation(fields: [ticketId], references: [id])

  @@unique([competitionId, ticketNumber])
}

model StripePayment {
  id             String   @id @default(uuid())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  amount         Float
  currency       String   @default("USD")
  status         String   @default("pending") // pending / success / failed
  type           String?

  stripePaymentId String?
  sessionId       String?

  competitionId Int?
  competition   Competition? @relation(fields: [competitionId], references: [id])
  quantity      Int?
  tickets       Ticket[]
  walletTransactions WalletTransaction[]

  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt     DateTime?  @updatedAt @db.Timestamp(0)
}

model Cart {
  id               Int             @id @default(autoincrement())
  userId           Int             @unique 
  user             User            @relation(fields: [userId], references: [id])
  items            CartItem[]
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @db.Timestamp(0)
}

model CartItem {
  id               Int             @id @default(autoincrement())
  cartId           Int             
  itemId           Int             
  quantity         Int
  itemType         itemTypeEnum   @default(competition)
  answer           String?
  cart Cart @relation(fields: [cartId], references: [id])    

  @@unique([cartId, itemId, itemType])                                               
}

model Ticket {
  id            String   @id @default(uuid())

  competitionId Int
  userId        Int
  paymentId     String   // instead of orderId

  ticketNumber  Int
  ticketCode    String?
  isEligible    Boolean
  isInstantWin  Boolean @default(false)

  createdAt     DateTime? @default(now()) @db.Timestamp(0)
  updatedAt     DateTime? @db.Timestamp(0)

  competition Competition @relation(fields: [competitionId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  payment     StripePayment @relation(fields: [paymentId], references: [id])

  results       Result[]
  instantWin    InstantWin?

  @@unique([competitionId, ticketNumber])
}

model Result {
  id            String   @id @default(uuid())

  competitionId Int
  userId        Int
  ticketId      String

  position      Int   // 1 = winner, 2 = runner-up, 3 = runner-up
  isManual      Boolean @default(false)
  winnerImage   String? 

  createdAt     DateTime @default(now())

  competition   Competition @relation(fields: [competitionId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
  ticket        Ticket      @relation(fields: [ticketId], references: [id])

  @@unique([competitionId, position]) // only one winner per position
}

model Contact {
  id          Int             @id @default(autoincrement())
  fullName    String
  phone       String?
  email       String
  subject     String
  message     String

  createdAt         DateTime? @default(now()) @db.Timestamp(0)
  deletedAt         DateTime? @db.Timestamp(0)
}

