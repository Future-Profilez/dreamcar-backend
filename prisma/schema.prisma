generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                 @id @default(autoincrement())
  name                 String
  email                String              @unique
  password             String
  role                 String              @default("user")
  createdAt            DateTime?           @default(now()) @db.Timestamp(0)
  deletedAt            DateTime?           @db.Timestamp(0)
  updatedAt            DateTime?           @db.Timestamp(0)
  otp                  String?
  otpAttempts          Int?                @default(0)
  otpExpiresAt         DateTime?
  otpVerifiedAt        DateTime?
  blockedAt            DateTime?           @db.Timestamp(0)
  isBlocked            Int                 @default(0)
  marketingEmails      Int                 @default(1)
  memberNumber         Int                 @unique @default(autoincrement())
  phone                String?
  cart                 Cart?
  purchasedGiftCredits GiftCredit[]        @relation("PurchasedGift")
  redeemedGiftCredits  GiftCredit[]        @relation("RedeemedGift")
  instantWins          InstantWin[]
  results              Result[]
  payments             StripePayment[]
  tickets              Ticket[]
  wallet               Wallet?
  walletTransactions   WalletTransaction[]
}

model Competition {
  id                       Int                  @id @default(autoincrement())
  title                    String
  images                   String[]
  detail                   String
  ticketPrice              Decimal              @db.Decimal(10, 2)
  totalTickets             Int
  soldTickets              Int                  @default(0)
  startTime                DateTime
  endTime                  DateTime
  createdAt                DateTime?            @default(now()) @db.Timestamp(0)
  deletedAt                DateTime?            @db.Timestamp(0)
  status                   Int                  @default(1)
  updatedAt                DateTime?            @db.Timestamp(0)
  productType              productTypeEnum      @default(car_bike)
  instantWinEnabled        Boolean              @default(false)
  instantWinTriggerPercent Int?
  instantWinGenerated      Boolean              @default(false)
  slug                     String?              @unique
  isFeatured               Int                  @default(0)
  endingEmailSent          Int                  @default(0)
  newEmailSent             Int                  @default(0)
  isHero                   Int                  @default(0)
  reservedTickets          Int                  @default(0)
  shuffleKey               String?
  questions                ComplianceQuestion[]
  contentSections          ContentSection[]
  instantWins              InstantWin[]
  instantWinPrizes         InstantWinPrize[]
  prizes                   Prize[]
  results                  Result[]
  payments                 StripePayment[]
  tickets                  Ticket[]
  reservations             TicketReservation[]
  winnerDetail             WinnerDetail?
}

model TicketReservation {
  id            String      @id @default(uuid())
  sessionId     String
  competitionId Int
  userId        Int
  quantity      Int
  status        String      @default("reserved")
  expiresAt     DateTime
  createdAt     DateTime    @default(now()) @db.Timestamp(0)
  updatedAt     DateTime?   @updatedAt @db.Timestamp(0)
  competition   Competition @relation(fields: [competitionId], references: [id])

  @@unique([sessionId, competitionId])
  @@index([status, expiresAt])
}

model Prize {
  id               String      @id @default(uuid())
  competitionId    Int
  title            String
  prizeDetail      String
  prizeDetailImage String
  prizeFeatures    String[]
  position         Int
  createdAt        DateTime?   @default(now()) @db.Timestamp(0)
  updatedAt        DateTime?   @db.Timestamp(0)
  deletedAt        DateTime?   @db.Timestamp(0)
  competition      Competition @relation(fields: [competitionId], references: [id])

  @@unique([competitionId, position])
}

model ContentSection {
  id            String      @id @default(uuid())
  competitionId Int
  title         String
  image         String?
  video         String?
  description   String
  specs         String[]
  position      Int
  createdAt     DateTime?   @default(now()) @db.Timestamp(0)
  updatedAt     DateTime?   @db.Timestamp(0)
  deletedAt     DateTime?   @db.Timestamp(0)
  competition   Competition @relation(fields: [competitionId], references: [id])
}

model ComplianceQuestion {
  id            String      @id @default(uuid())
  competitionId Int
  question      String
  answers       String[]
  options       String[]
  competition   Competition @relation(fields: [competitionId], references: [id])
}

model InstantWinPrize {
  id            String       @id @default(uuid())
  competitionId Int
  title         String
  image         String?
  quantity      Int
  wins          InstantWin[]
  competition   Competition  @relation(fields: [competitionId], references: [id])
}

model InstantWin {
  id            String          @id @default(uuid())
  competitionId Int
  prizeId       String
  ticketNumber  Int
  isClaimed     Boolean         @default(false)
  claimedById   Int?
  claimedAt     DateTime?
  ticketId      String?         @unique
  position      Int?
  claimedBy     User?           @relation(fields: [claimedById], references: [id])
  competition   Competition     @relation(fields: [competitionId], references: [id])
  prize         InstantWinPrize @relation(fields: [prizeId], references: [id])
  ticket        Ticket?         @relation(fields: [ticketId], references: [id])

  @@unique([competitionId, ticketNumber])
}

model StripePayment {
  id                 String              @id @default(uuid())
  userId             Int
  amount             Float
  currency           String              @default("USD")
  status             String              @default("pending")
  stripePaymentId    String?
  sessionId          String?             @unique
  competitionId      Int?
  quantity           Int?
  createdAt          DateTime?           @default(now()) @db.Timestamp(0)
  updatedAt          DateTime?           @updatedAt @db.Timestamp(0)
  type               String?
  competition        Competition?        @relation(fields: [competitionId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  tickets            Ticket[]
  walletTransactions WalletTransaction[]
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  createdAt DateTime?  @default(now()) @db.Timestamp(0)
  updatedAt DateTime?  @db.Timestamp(0)
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id       Int          @id @default(autoincrement())
  cartId   Int
  itemId   Int
  quantity Int
  itemType itemTypeEnum @default(competition)
  answer   String?
  cart     Cart         @relation(fields: [cartId], references: [id])

  @@unique([cartId, itemId, itemType])
}

model Ticket {
  id            String        @id @default(uuid())
  competitionId Int
  userId        Int
  paymentId     String
  ticketNumber  Int
  isEligible    Boolean
  isInstantWin  Boolean       @default(false)
  createdAt     DateTime?     @default(now()) @db.Timestamp(0)
  ticketCode    String?
  updatedAt     DateTime?     @db.Timestamp(0)
  deletedAt     DateTime?     @db.Timestamp(0)
  instantWin    InstantWin?
  results       Result[]
  competition   Competition   @relation(fields: [competitionId], references: [id])
  payment       StripePayment @relation(fields: [paymentId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@unique([competitionId, ticketNumber])
}

model Result {
  id            String        @id @default(uuid())
  competitionId Int
  userId        Int
  ticketId      String
  position      Int
  isManual      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  winnerImage   String?
  competition   Competition   @relation(fields: [competitionId], references: [id])
  ticket        Ticket        @relation(fields: [ticketId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  winnerDetail  WinnerDetail?

  @@unique([competitionId, position])
}

model Contact {
  id        Int       @id @default(autoincrement())
  fullName  String
  phone     String?
  email     String
  subject   String
  message   String
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  deletedAt DateTime? @db.Timestamp(0)
}

model Wallet {
  id           Int                 @id @default(autoincrement())
  userId       Int                 @unique
  balance      Decimal             @default(0) @db.Decimal(10, 2)
  createdAt    DateTime?           @default(now()) @db.Timestamp(0)
  updatedAt    DateTime?           @updatedAt @db.Timestamp(0)
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id              Int                   @id @default(autoincrement())
  userId          Int
  amount          Decimal               @db.Decimal(10, 2)
  reason          String
  balance         Decimal               @db.Decimal(10, 2)
  createdAt       DateTime?             @default(now()) @db.Timestamp(0)
  stripePaymentId String?
  walletId        Int
  type            WalletTransactionType
  stripePayment   StripePayment?        @relation(fields: [stripePaymentId], references: [id])
  user            User                  @relation(fields: [userId], references: [id])
  wallet          Wallet                @relation(fields: [walletId], references: [id])
}

model GiftCredit {
  id              Int       @id @default(autoincrement())
  amount          Decimal   @db.Decimal(10, 2)
  expiresAt       DateTime?
  redeemedAt      DateTime?
  createdAt       DateTime? @default(now()) @db.Timestamp(0)
  isRedeemed      Int       @default(0)
  code            String    @unique
  purchasedById   Int?
  redeemedById    Int?
  purchasedByUser User?     @relation("PurchasedGift", fields: [purchasedById], references: [id])
  redeemedByUser  User?     @relation("RedeemedGift", fields: [redeemedById], references: [id])
}

model GiftCardProduct {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  image       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime? @default(now()) @db.Timestamp(0)
  updatedAt   DateTime? @updatedAt @db.Timestamp(0)
}

model CurrencyRate {
  id        Int       @id @default(autoincrement())
  currency  String    @unique
  rate      Float
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @updatedAt @db.Timestamp(0)
}

model WinnerDetail {
  id               Int         @id @default(autoincrement())
  competitionId    Int         @unique
  resultId         String      @unique
  winnerName       String
  winnerLocation   String?
  storyDescription String?
  winnerImage      String?
  galleryImages    String[]
  createdAt        DateTime?   @default(now()) @db.Timestamp(0)
  updatedAt        DateTime?   @db.Timestamp(0)
  deletedAt        DateTime?   @db.Timestamp(0)
  competition      Competition @relation(fields: [competitionId], references: [id])
  result           Result      @relation(fields: [resultId], references: [id])
}

model Newsletter {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  createdAt DateTime? @default(now()) @db.Timestamp(0)
  deletedAt DateTime? @db.Timestamp(0)
  fullName  String
  phone     String?
}

model AdminNotification {
  id        String    @id @default(uuid())
  key       String?   @unique
  type      String
  title     String
  message   String
  meta      Json?
  isRead    Boolean   @default(false)
  createdAt DateTime? @default(now()) @db.Timestamp(0)
}

enum productTypeEnum {
  car_bike
  tech_luxury
  cash
}

enum itemTypeEnum {
  competition
  gift_card
  gift_credit
}

enum WalletTransactionType {
  credit
  debit
}
